<section class="m-cart-page">
  <div class="m-page">
    <p class="m-eyebrow">Mireani</p>
    <h1>Your cart</h1>
    {% if cart.item_count == 0 %}
      <div class="m-empty-cart">
        <p>Your cart is empty.</p>
        <a class="m-btn" href="/collections/all">Continue shopping</a>
      </div>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <div class="m-cart-list">
          {% for item in cart.items %}
            <div class="m-cart-item">
              <div>{% if item.image %}{{ item.image | image_url: width: 160 | image_tag: loading: 'lazy', alt: item.product.title }}{% endif %}</div>
              <div><h2>{{ item.product.title }}</h2>{% unless item.product.has_only_default_variant %}<p>{{ item.variant.title }}</p>{% endunless %}{% for property in item.properties %}{% if property.last != blank %}<p><strong>{{ property.first }}:</strong> {{ property.last }}</p>{% endif %}{% endfor %}</div>
              <div><input class="m-input" type="number" name="updates[]" value="{{ item.quantity }}" min="0"></div>
              <div><strong>{{ item.final_line_price | money }}</strong></div>
            </div>
          {% endfor %}
        </div>
        <div class="m-cart-summary"><p>Total: <strong>{{ cart.total_price | money }}</strong></p><button class="m-btn m-btn-light" type="submit" name="update">Update</button><button class="m-btn" type="submit" name="checkout">Checkout</button></div>
      </form>
    {% endif %}
  </div>
</section>
