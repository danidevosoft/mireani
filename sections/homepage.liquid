<section class="m-hero3d m-hero-compact">
  <div class="m-orb m-orb-one"></div>
  <div class="m-orb m-orb-two"></div>
  <div class="m-page m-hero3d-grid">
    <div class="m-hero-copy">
      <p class="m-eyebrow">Personalized gift studio</p>
      <h1>Custom gifts made with your photo, names and story.</h1>
      <p class="m-lead">Create a clean personalized keepsake in minutes. Upload your details, place the order, and we prepare it on demand with care.</p>
      <div class="m-actions"><a class="m-btn" href="/products/personalized-couple-poster-our-story">Start personalization</a><a class="m-btn m-btn-light" href="/pages/contact">Ask a question</a></div>
      <div class="m-trust"><span>Personalized</span><span>Photo upload</span><span>Gift ready</span></div>
    </div>
    <div class="m-orbit-stage" aria-hidden="true">
      <div class="m-orbit-ring"></div>
      <div class="m-glass-card main"><span>Photo</span><b>Names</b><em>Date</em></div>
      <div class="m-glass-card one">Gift</div>
      <div class="m-glass-card two">Print</div>
      <div class="m-glass-card three">Care</div>
    </div>
  </div>
</section>

<section class="m-section m-soft m-compact-section">
  <div class="m-page">
    <div class="m-steps m-steps-compact">
      <div><b>1</b><h3>Upload</h3><p>Add your photo and personalization details.</p></div>
      <div><b>2</b><h3>Customize</h3><p>Choose names, date, style and short message.</p></div>
      <div><b>3</b><h3>Order</h3><p>We prepare your custom gift on demand.</p></div>
    </div>
  </div>
</section>

{% schema %}
{"name":"Homepage","settings":[]}
{% endschema %}
