<header class="m-header">
  <div class="m-page m-header__inner">
    <a class="m-logo m-logo-mark" href="{{ routes.root_url }}" aria-label="Mireani home">
      <span class="m-logo-symbol" aria-hidden="true">
        <svg viewBox="0 0 96 96" role="img"><defs><linearGradient id="mireaniLogoGradient" x1="12" y1="8" x2="84" y2="88" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#c79a76"/><stop offset="0.45" stop-color="#f4dfcf"/><stop offset="1" stop-color="#6d4c3d"/></linearGradient></defs><circle cx="48" cy="48" r="42" fill="url(#mireaniLogoGradient)"/><circle cx="48" cy="48" r="34" fill="none" stroke="rgba(255,255,255,.72)" stroke-width="2"/><path d="M26 58C36 32 58 29 70 44C56 41 46 48 42 66C37 58 32 56 26 58Z" fill="#fffaf5" opacity=".95"/><path d="M30 37C41 18 62 17 75 31C60 30 50 36 43 52C39 43 35 39 30 37Z" fill="#ffffff" opacity=".78"/><path d="M30 66C48 71 65 65 73 51" fill="none" stroke="#fff" stroke-width="4" stroke-linecap="round" opacity=".9"/></svg>
      </span>
      <span class="m-logo-textwrap"><span class="m-logo-word">Mireani</span><span class="m-logo-tagline">Made on demand with care</span></span>
    </a>
    <nav class="m-nav" aria-label="Main navigation">
      <a href="{{ routes.root_url }}">Home</a>
      <a href="/collections/all">Products</a>
      <a href="/pages/contact">Contact</a>
      <a href="/pages/terms-and-conditions">Terms</a>
      <a href="/pages/return-policy">Returns</a>
    </nav>
    <div class="m-header__icons">
      <form class="m-search m-header-search" action="{{ routes.search_url }}" method="get" role="search">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10.8 18.1a7.3 7.3 0 1 1 0-14.6 7.3 7.3 0 0 1 0 14.6Z" fill="none" stroke="currentColor" stroke-width="2"/><path d="m16.2 16.2 4.1 4.1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <input type="search" name="q" placeholder="Search" aria-label="Search">
      </form>
      <a class="m-cart-link" href="{{ routes.cart_url }}" aria-label="Coș">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.5 8.5h11l-1 10h-9l-1-10Z" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M9 8.5a3 3 0 0 1 6 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        <span>Coș</span>
        {% if cart.item_count > 0 %}<b>{{ cart.item_count }}</b>{% endif %}
      </a>
    </div>
  </div>
</header>

{% schema %}
{"name":"Header","settings":[]}
{% endschema %}
